#!/usr/bin/env bash

set -Eeuo pipefail

# Easy-RSA 3.2.x-compatible replacement for the DNXLabs helper.
# Usage: ovpn_revokeclient CN [keep|remove]

# shellcheck source=/usr/local/lib/ovpn_pki_lib
source "${OVPN_PKI_LIB:-/usr/local/lib/ovpn_pki_lib}"

CN="${1:-}"
MODE="${2:-keep}"

[ -n "$CN" ] || die "Usage: ovpn_revokeclient CN [keep|remove]"
validate_identity "$CN"

case "$MODE" in
    keep|remove) ;;
    *) die "Second argument must be 'keep' or 'remove'" ;;
esac

require_command easyrsa
ensure_pki_exists
require_file "$EASYRSA_PKI/issued/$CN.crt"

LOCK_ACQUIRED=false
if [ "${PKI_LOCK_HELD:-false}" != "true" ]; then
    acquire_pki_lock
    LOCK_ACQUIRED=true
    trap cleanup_on_exit EXIT
fi

log "Revoking certificate: $CN"
easyrsa --batch revoke "$CN"
log "Generating CRL"
easyrsa --batch gen-crl

cp -f "$EASYRSA_PKI/crl.pem" "$OPENVPN/crl.pem"
chmod 644 "$OPENVPN/crl.pem"

if [ "$MODE" = "remove" ]; then
    rm -f \
        "$EASYRSA_PKI/issued/$CN.crt" \
        "$EASYRSA_PKI/private/$CN.key" \
        "$EASYRSA_PKI/reqs/$CN.req"
    log "Removed issued certificate, private key, and request for $CN"
fi

if [ "$LOCK_ACQUIRED" = true ]; then
    release_pki_lock
    trap - EXIT
fi

log "Revocation completed: $CN"
